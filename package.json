{
  "name": "pex-crawler",
  "version": "1.0.0",
  "description": "",
  "homepage": "https://github.com/tomacheese/pex-crawler",
  "bugs": {
    "url": "https://github.com/tomacheese/pex-crawler/issues"
  },
  "license": "MIT",
  "author": "Tomachi <tomachi@tomacheese.com>",
  "private": true,
  "main": "dist/main.js",
  "repository": {
    "url": "git@github.com:tomacheese/pex-crawler.git",
    "type": "git"
  },
  "scripts": {
    "fix:prettier": "prettier --write src",
    "lint:tsc": "tsc",
    "test": "jest --runInBand --passWithNoTests --detectOpenHandles --forceExit",
    "fix": "run-z fix:prettier fix:eslint",
    "lint": "run-z lint:prettier,lint:eslint,lint:tsc",
    "start": "tsx ./src/main.ts",
    "dev": "tsx watch ./src/main.ts",
    "fix:eslint": "eslint . -c eslint.config.mjs --fix",
    "lint:eslint": "eslint . -c eslint.config.mjs",
    "lint:prettier": "prettier --check src",
    "generate-schema": "typescript-json-schema --required src/config.ts ConfigInterface -o schema/Configuration.json"
  },
  "devDependencies": {
    "@book000/eslint-config": "1.16.14",
    "@book000/node-utils": "1.25.1",
    "@types/jest": "30.0.0",
    "@types/node": "24.13.3",
    "cheerio": "1.2.0",
    "eslint": "10.7.0",
    "eslint-config-standard": "17.1.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-n": "18.2.2",
    "eslint-plugin-promise": "7.3.0",
    "jest": "30.4.2",
    "jest-expect-message": "1.1.3",
    "prettier": "3.9.5",
    "run-z": "2.1.0",
    "ts-jest": "29.4.11",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "typescript-json-schema": "0.68.0"
  },
  "jest": {
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    },
    "moduleFileExtensions": [
      "js",
      "ts"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "setupFilesAfterEnv": [
      "jest-expect-message"
    ]
  },
  "packageManager": "pnpm@11.15.0+sha512.266f8957a30d2be6e9468e5e66bcdedd35a794175f71b067ba8504d686cce1d0c0f429b33c323c3c569ad4891e667574a49ff71d1b89a22cc66f13c65818c578"
}
